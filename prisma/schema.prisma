generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String    @id @default("user_") @db.VarChar(50)
  username        String    @unique @map("username") @db.VarChar(100)
  passwordHash    String    @map("password_hash") @db.VarChar(255)
  createdAt       DateTime  @default(now()) @map("created_at")
  quotaLimit      Int?      @map("quota_limit")
  quotaWindowHours Int?     @map("quota_window_hours")
  sessions        Session[]
  conversations   Conversation[]
  images          Image[]

  @@map("users")
}

model Session {
  id        String   @id @default(uuid()) @db.VarChar(50)
  userId    String   @map("user_id") @db.VarChar(50)
  token     String   @unique @map("token") @db.VarChar(100)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Conversation {
  id         String    @id @default(uuid()) @db.VarChar(50)
  userId     String    @map("user_id") @db.VarChar(50)
  title      String    @db.VarChar(255)
  messages   Message[]
  artifacts  Json?     @default("{}") @db.Json
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("conversations")
}

model Message {
  id              String        @id @default(uuid()) @db.VarChar(50)
  conversationId  String        @map("conversation_id") @db.VarChar(50)
  role            String        @db.VarChar(20)
  content         String        @db.Text
  contentBlocks   Json?         @db.Json
  thinking        String?       @db.Text
  attachedImages  Json?         @default("[]") @db.Json
  timestamp       BigInt        @db.BigInt
  conversation    Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@map("messages")
}

model Image {
  id        String   @id @default(uuid()) @db.VarChar(50)
  userId    String   @map("user_id") @db.VarChar(50)
  fileName  String   @map("file_name") @db.VarChar(255)
  mimeType  String   @map("mime_type") @db.VarChar(100)
  data      String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("images")
}

model TokenQuota {
  id           String @id @default(uuid()) @db.VarChar(50)
  userId       String @unique @map("user_id") @db.VarChar(50)
  usedTokens   BigInt @default(0) @map("used_tokens")
  windowStart  BigInt @map("window_start")
  limitTokens  BigInt @map("limit_tokens")
  windowHours  Int    @map("window_hours")

  @@map("token_quotas")
}
